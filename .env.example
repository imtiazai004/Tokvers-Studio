# ============================================================
# DEVELOPER ONLY — Set once by developer, not exposed to clients
# ============================================================

# TikTok Developer App — one app for all clients (OAuth + Content Posting)
# Register at: developer.tiktok.com → Create App → Apply for Content Posting API
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# TikTok Shop Partner API — sales feedback loop
# Register at: partner.tiktokshop.com
TIKTOK_SHOP_APP_KEY=your_app_key
TIKTOK_SHOP_APP_SECRET=your_app_secret
TIKTOK_SHOP_ACCESS_TOKEN=your_access_token

# ============================================================
# CLIENT CONFIGURATION — Each client enters via Settings page
# These can also be set here as a fallback default
# ============================================================

ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_MALE=pNInz6obpgDQGcFmaJgB
ELEVENLABS_VOICE_ID_FEMALE=EXAVITQu4vr4xnSDxMaL
GROK_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
APIFY_API_TOKEN=
BRAVE_SEARCH_API_KEY=
DEEPGRAM_API_KEY=

# ============================================================
# APP SETTINGS
# ============================================================
OUTPUT_DIR=output
MAX_SCENES=10
DEFAULT_VIDEO_TOOL=grok

# Secret for signing login session cookies (set a long random value in prod)
SESSION_SECRET=

